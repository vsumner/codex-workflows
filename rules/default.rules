prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "push", "origin"], decision="allow")
prefix_rule(pattern=["git", "stash"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["git", "restore"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-B"], decision="allow")
prefix_rule(pattern=["git", "cherry-pick"], decision="allow")
prefix_rule(pattern=["git", "worktree", "add"], decision="allow")
prefix_rule(pattern=["git", "merge", "--ff-only"], decision="allow")
prefix_rule(pattern=["git", "branch", "-D"], decision="allow")
prefix_rule(pattern=["git", "fetch", "origin"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "https://github.com/am-will/swarms.git"], decision="allow")

prefix_rule(pattern=["gh", "pr"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "edit"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")

prefix_rule(pattern=["cargo", "check"], decision="allow")
prefix_rule(pattern=["devenv", "shell"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["bash", "scripts/pilot-pnpm-onix.sh"], decision="allow")
prefix_rule(pattern=["target/debug/spacebot", "start"], decision="allow")

prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/status"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/agents/warmup"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/agents/workers"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/channels/status"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/messaging/status"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "http://127.0.0.1:19898/api/channels/messages"], decision="allow")
prefix_rule(pattern=["perl", "-0pi", "-e"], decision="allow")
