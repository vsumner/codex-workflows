# Example shareable Codex config exported from `~/.codex`.
# Secrets, per-project trust entries, and machine-specific paths are omitted.
# Copy this to `~/.codex/config.toml` and then add your own `[projects."..."]` blocks locally.
# Set required env vars such as `CONTEXT7_API_KEY` in your shell.

model = "gpt-5.4"
review_model = "gpt-5.4"
plan_mode_reasoning_effort = "xhigh"
model_reasoning_effort = "high"
personality = "pragmatic"

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
env_vars = ["CONTEXT7_API_KEY"]
startup_timeout_ms = 20_000

[notice.model_migrations]
"gpt-5.2" = "gpt-5.2-codex"
"gpt-5.1-codex-max" = "gpt-5.2-codex"

[features]
unified_exec = true
shell_snapshot = true
multi_agent = true
child_agents_md = true
fast_mode = true
default_mode_request_user_input = true
js_repl = true
prevent_idle_sleep = true
apps = true

# Optional native capability bundles to enable once you want them in your stack:
# plugins = true
# guardian_approval = true
# request_permissions_tool = true
# js_repl_tools_only = true  # advanced: route direct tool use through `js_repl` + `codex.tool(...)`

# Optional named permissions profiles.
# Add these if you want structured filesystem/network escalation through
# native `request_permissions` rather than only free-form user approval.
#
# default_permissions = "workspace"
#
# [permissions.workspace.filesystem]
# ":minimal" = "read"
#
# [permissions.workspace.filesystem.":project_roots"]
# "." = "write"
# "docs" = "read"
#
# [permissions.workspace.network]
# enabled = false

[history]
persistence = "save-all"
max_bytes = 268_435_456

[agents]
max_depth = 4
max_threads = 8
job_max_runtime_seconds = 1800

[agents.worker]
description = "Execution worker tuned for fast iterative implementation tasks"
config_file = "roles/worker.toml"

[agents.workflow_orchestrator]
description = "Canonical non-coding orchestrator for Victor's phase-first RPIV workflow"
config_file = "roles/workflow_orchestrator.toml"

[agents.research_locator]
description = "Fast read-only file and dependency inventory for the Research phase"
config_file = "roles/research_locator.toml"

[agents.architecture_analyst]
description = "Deep read-only architecture and control-flow analysis for the Research phase"
config_file = "roles/architecture_analyst.toml"

[agents.spark_implementer]
description = "Default Spark implementation worker for bounded packets"
config_file = "roles/spark_implementer.toml"

[agents.spark_implementer_xhigh]
description = "High-effort Spark worker for hard but bounded packets"
config_file = "roles/spark_implementer_xhigh.toml"

[agents.learning_tester]
description = "Runs small proof probes before planning or implementation"
config_file = "roles/learning_tester.toml"

[agents.plan_reviewer]
description = "Reviews canonical plans and executable graphs for execution clarity"
config_file = "roles/plan_reviewer.toml"

[agents.packet_verifier]
description = "Verifies one implementation packet before it is accepted"
config_file = "roles/packet_verifier.toml"

[agents.workflow_verifier]
description = "Leads the Verify phase and tracks assertion state with evidence"
config_file = "roles/workflow_verifier.toml"

[agents.scrutiny_validator]
description = "Runs code scrutiny validation against the validation contract"
config_file = "roles/scrutiny_validator.toml"

[agents.user_flow_validator]
description = "Runs user-surface validation against the validation contract"
config_file = "roles/user_flow_validator.toml"

[agents.workflow_reviewer]
description = "Final reviewer for risky team runs and deep-team gates"
config_file = "roles/workflow_reviewer.toml"

[agents.planner]
description = "Breaks work into checkpointed execution plans with explicit gates"
config_file = "roles/planner.toml"

[agents.implementer]
description = "Implements scoped tasks and verifies changes with local checks"
config_file = "roles/implementer.toml"

[agents.spec_reviewer]
description = "Reviews plans and patches for spec compliance and requirement coverage"
config_file = "roles/spec_reviewer.toml"

[agents.quality_reviewer]
description = "Finds regressions, missing tests, and quality risks before handoff"
config_file = "roles/quality_reviewer.toml"

[agents.reviewer]
description = "High-signal general code reviewer for final handoff readiness"
config_file = "roles/reviewer.toml"

[agents.researcher]
description = "Performs read-only code and docs research with source-backed findings"
config_file = "roles/researcher.toml"

[agents.rust_correctness_reviewer]
description = "Strict Rust correctness reviewer for async/state/race regressions"
config_file = "roles/rust_correctness_reviewer.toml"

[agents.integrator]
description = "Integrates reviewed changes, resolves merge conflicts, and prepares final handoff"
config_file = "roles/integrator.toml"

[agents.reuse_reviewer]
description = "Finds duplicate logic and recommends existing helpers/utilities to reuse"
config_file = "roles/reuse_reviewer.toml"

[agents.efficiency_reviewer]
description = "Finds performance and resource-efficiency issues in changed code"
config_file = "roles/efficiency_reviewer.toml"

[agents.history_reviewer]
description = "Reviews PR and branch history for intent and rationale context"
config_file = "roles/history_reviewer.toml"

[agents.instruction_compliance_reviewer]
description = "Checks project-instruction compliance and changed comment/doc alignment"
config_file = "roles/instruction_compliance_reviewer.toml"
